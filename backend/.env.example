# X AI Otomasyon - Environment Variables
# Copy this file to .env and fill in your values

# App
APP_PASSWORD=your_dashboard_password

# AI Providers (at least one required)
MINIMAX_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Grok / xAI
XAI_API_KEY=

# Twitter/X API
TWITTER_BEARER_TOKEN=
TWITTER_CT0=
TWITTER_AUTH_TOKEN=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
